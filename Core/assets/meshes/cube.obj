# cube.obj
mtllib cube.mtl
o Cube

# Vertex positions
v -1.0 -1.0 -1.0   # 1
v -1.0 -1.0  1.0   # 2
v -1.0  1.0 -1.0   # 3
v -1.0  1.0  1.0   # 4
v  1.0 -1.0 -1.0   # 5
v  1.0 -1.0  1.0   # 6
v  1.0  1.0 -1.0   # 7
v  1.0  1.0  1.0   # 8

# Texture coordinates (reused for each face)
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Normals for each face
vn  0.0  0.0  1.0   # Front face normal
vn  0.0  0.0 -1.0   # Back face normal
vn -1.0  0.0  0.0   # Left face normal
vn  1.0  0.0  0.0   # Right face normal
vn  0.0  1.0  0.0   # Top face normal
vn  0.0 -1.0  0.0   # Bottom face normal

# Each face is assigned its own material.

# Front face (z = 1): vertices 2, 4, 8, 6
usemtl t1
f 2/1/1 4/2/1 8/3/1 6/4/1

# Back face (z = -1): vertices 1, 3, 7, 5
usemtl t2
f 1/1/2 3/2/2 7/3/2 5/4/2

# Left face (x = -1): vertices 1, 2, 4, 3
usemtl t3
f 1/1/3 2/2/3 4/3/3 3/4/3

# Right face (x = 1): vertices 5, 6, 8, 7
usemtl t4
f 5/1/4 6/2/4 8/3/4 7/4/4

# Top face (y = 1): vertices 3, 4, 8, 7
usemtl t5
f 3/1/5 4/2/5 8/3/5 7/4/5

# Bottom face (y = -1): vertices 1, 2, 6, 5
usemtl t6
f 1/1/6 2/2/6 6/3/6 5/4/6
